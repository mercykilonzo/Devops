# Copy to .env and fill in real values:  cp .env.example .env
# The real .env is gitignored and must NOT be committed.
#
# Used by docker-compose.prod.yml and scripts/deploy.sh.

# Your Docker Hub username (lowercase).
DOCKERHUB_USERNAME=your-dockerhub-username

# App/repo name used in image names (lowercase). For this repo: devops
APP_NAME=devops

# The image version to deploy — a commit-pinned tag, never "latest".
# Example: sha-a1b2c3d
IMAGE_TAG=sha-xxxxxxx
